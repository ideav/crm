# Шаблон .env.local для Docker-пути с ручным запуском compose.
# Обычно этот файл создаёт установщик scripts/install-local-docker.sh автоматически.
# Заполняйте вручную только если запускаете compose без установщика:
#   cp local/files/env.example .env.local
#   nano .env.local
#   docker compose --env-file .env.local up -d --build
#
# ВАЖНО: не оставляйте значения-примеры на рабочей установке — задайте свои.

# Пароль администратора Интеграма (вход admin). Минимум 8 символов.
INTEGRAM_MASTER_PASSWORD=ЗАМЕНИТЕ-master-пароль

# База данных (внутри compose имя хоста БД — 'db', менять не нужно).
INTEGRAM_DB_NAME=ideav
INTEGRAM_DB_USER=ideav
INTEGRAM_DB_PASSWORD=ЗАМЕНИТЕ-пароль-БД
INTEGRAM_DB_ROOT_PASSWORD=ЗАМЕНИТЕ-root-пароль-БД

# Соль для хешей. Сгенерировать: openssl rand -hex 24
INTEGRAM_SALT=ЗАМЕНИТЕ-случайная-строка

# Порты на хосте (снаружи). Для стандартных поставьте 80 и 443.
INTEGRAM_HTTP_PORT=8080
INTEGRAM_HTTPS_PORT=8443

# E-mail администратора.
INTEGRAM_ADMIN_EMAIL=admin@example.local
